    "entryNodeId": "scene-lobby",
    "variables": [
      {
        "id": "opened_profile",
        "name": "Opened Profile",
        "type": "boolean",
        "initialValue": false,
        "description": "Tracks whether the visitor reached the profile route."
      }
    ],
    "nodes": {
      "scene-lobby": {
        "id": "scene-lobby",
        "kind": "scene",
        "backgroundId": "bg-studio-lobby",
        "next": "intro-line",
        "actorPlacement": {
          "position": {
            "x": 0.5,
            "y": 0.85
          },
          "scale": 0.88
        }
      },
      "intro-line": {
        "id": "intro-line",
        "kind": "dialogue",
        "actorId": "actor-host",
        "text": "This editor preview uses the same player-core and pixi-player stack as runtime.",
        "next": "route-choice",
        "actorPlacement": {
          "position": {
            "x": 0.5095,
            "y": 1.8507
          },
          "scale": 2.1827
        },
        "clipId": "intro-line-clip",
        "voiceAudioId": "voice-intro-line-clip",
        "spriteAnimationId": "intro-line-clip-sprite"
      },
      "route-choice": {
        "id": "route-choice",
        "kind": "choice",
        "prompt": "Which route should this electronic card emphasize first?",
        "options": [
          {
            "id": "profile-route",
            "label": "Lead visitors to the profile card",
            "next": "set-profile-opened"
          },
          {
            "id": "social-route",
            "label": "Jump straight to social links",
            "next": "social-line"
          }
        ]
      },
      "set-profile-opened": {
        "id": "set-profile-opened",
        "kind": "setVariable",
        "variableId": "opened_profile",
        "value": true,
        "next": "profile-line"
      },
      "profile-line": {
        "id": "profile-line",
        "kind": "dialogue",
        "actorId": "actor-host",
        "text": "Good. This route can frame the VTuber first, then guide viewers toward links and featured content.",
        "next": "finish"
      },
      "social-line": {
        "id": "social-line",
        "kind": "dialogue",
        "actorId": "actor-host",
        "text": "Direct routes still work, but the card should retain a sense of interaction and authored pacing.",
        "next": "finish"
      },
      "finish": {
        "id": "finish",
        "kind": "end",
        "endingId": "editor-demo-end",
        "title": "Preview complete"
      }
    }
  },
